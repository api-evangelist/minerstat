{
  "opencollection": "1.0.0",
  "info": {
    "name": "Minerstat Mining Pools API",
    "version": "2.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-API-Key",
      "value": "{{X-API-Key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Pools",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List mining pools",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.minerstat.com/v2/pools"
          },
          "docs": "Retrieve information about all mining pools listed on Minerstat. Pool data updates approximately once per minute. Throttled to roughly 12 requests per minute."
        }
      ]
    }
  ],
  "bundled": true
}